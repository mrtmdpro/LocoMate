DATABASE_URL=postgresql://locomate:locomate@localhost:5432/locomate
REDIS_URL=redis://localhost:6379

JWT_SECRET=change-me-to-a-random-256-bit-key
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

OPENAI_API_KEY=sk-...

# DeepSeek — OpenAI-compatible chat completions. Powers the Phase A AI
# mockup surfaces (chatbot quiz, dynamic re-routing, wrap-up storytelling)
# and the deterministic Thank-you Letter generator.
# Get a key at https://platform.deepseek.com/api_keys.
# Model: deepseek-chat (V3) for general text, deepseek-reasoner (R1) for
# personality-quiz scoring.
# Pricing (~2026): $0.27/M input tokens, $1.10/M output tokens.
DEEPSEEK_API_KEY=
# Default ON. When "true", every llm.* call returns hand-written mock
# content keyed by (feature, tone) — zero external API spend, fully
# deterministic, safe for screenshots. Flip to "false" in Phase C to
# enable real generation.
LLM_MOCK_MODE=true

NEXT_PUBLIC_GOOGLE_MAPS_KEY=

STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# Google OAuth (see docs/OAUTH_SETUP.md for Cloud Console setup)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Base URL used to build the OAuth redirect URI: ${OAUTH_REDIRECT_BASE}/api/auth/google/callback
# Dev: http://localhost:3000  Prod: https://loco-mate.vercel.app
OAUTH_REDIRECT_BASE=http://localhost:3000
